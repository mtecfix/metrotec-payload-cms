# Payload CMS Environment Variables
# Copy to .env and fill in values

# Database (Neon free tier: https://neon.tech)
DATABASE_URI=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/metrotec-cms?sslmode=require

# Payload
PAYLOAD_SECRET=CHANGE_ME_TO_RANDOM_STRING_32_CHARS
PAYLOAD_PUBLIC_SERVER_URL=https://metrotec-cms.vercel.app

# S3 Media Storage (uses your existing metrotec-www bucket)
S3_BUCKET=metrotec-www
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Admin user (created on first run)
PAYLOAD_ADMIN_EMAIL=mrtechfixes.ai@gmail.com
PAYLOAD_ADMIN_PASSWORD=MetroTec#Admin2026!
